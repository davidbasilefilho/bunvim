{
	"$schema": "https://opencode.ai/config.json",
	"lsp": {
		"biome": {
			"disabled": false,
			"command": ["bunx", "biome", "lsp-proxy"],
			"extensions": [
				".js",
				".mjs",
				".cjs",
				".ts",
				".mts",
				".cts",
				".d.ts",
				".jsx",
				".tsx",
				".css",
				".json",
				".jsonc",
				".graphql",
				".gql",
				".html",
				".vue",
				".svelte",
				".astro",
				".grit"
			]
		}
	}
}
