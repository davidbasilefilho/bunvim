{
	"name": "bunvim",
	"module": "src/index.tsx",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/index.tsx",
		"lint": "biome lint --write .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"build": "mise run build",
		"build:all": "mise run build:all",
		"build:linux": "mise run build:linux",
		"build:darwin": "mise run build:darwin",
		"build:windows": "mise run build:windows",
		"build:debug": "mise run build:debug",
		"build:linux:debug": "mise run build:linux:debug",
		"build:darwin:debug": "mise run build:darwin:debug",
		"build:windows:debug": "mise run build:windows:debug",
		"check-types": "biome check .",
		"test": "bun test",
		"test:watch": "bun test --watch"
	},
	"devDependencies": {
		"@types/bun": "^1.3.5"
	},
	"peerDependencies": {
		"typescript": "^5.9.2"
	},
	"dependencies": {
		"@opentui/core": "^0.1.63",
		"@opentui/react": "^0.1.63",
		"@vscode/debugadapter-testsupport": "^1.68.0",
		"@vscode/debugprotocol": "^1.68.0",
		"conf": "^15.0.2",
		"effect": "^3.19.13",
		"react": "^19.2.3",
		"tree-sitter": "^0.25.0",
		"tree-sitter-javascript": "^0.25.0",
		"tree-sitter-json": "^0.24.8",
		"tree-sitter-markdown": "^0.7.1",
		"tree-sitter-typescript": "^0.23.2",
		"ts-lsp-client": "^1.1.0"
	},
	"optionalDependencies": {
		"@opentui/core-darwin-arm64": "^0.1.63",
		"@opentui/core-linux-x64": "^0.1.63",
		"@opentui/core-win32-x64": "^0.1.63"
	}
}
