{
  "name": "@bunvim/editor",
  "version": "0.1.0",
  "bin": {
    "bvim": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "bun run ./build.ts",
    "build:all": "bun run build:linux && bun run build:darwin && bun run build:windows",
    "build:linux": "bun run ./build.ts -- linux",
    "build:darwin": "bun run ./build.ts -- darwin",
    "build:windows": "bun run ./build.ts -- windows",
    "dev": "bun --watch ./src/index.tsx",
    "lint": "oxlint --fix --fix-suggestions",
    "format": "oxfmt --write",
    "check": "bun run --parallel lint format",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@bunvim/sdk": "workspace:*",
    "@opentui/core": "0.1.77",
    "@opentui/solid": "0.1.77",
    "effect": "3.19.16",
    "solid-js": "1.9.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/bun": "^1.3.8",
    "babel-preset-solid": "^1.9.10",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@opentui/core-darwin-arm64": "0.1.77",
    "@opentui/core-linux-x64": "0.1.77",
    "@opentui/core-win32-x64": "0.1.77"
  }
}
